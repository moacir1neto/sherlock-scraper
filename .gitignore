# =========================
leads_exports/*
!leads_exports/.gitkeep

# =========================
# 🔒 ARQUIVOS DE AMBIENTE E SEGURANÇA (NUNCA SUBIR)
# =========================
.env
.env.*
.env.example
*.pem
*.key

# =========================
# 🐍 PYTHON (O Scraper original)
# =========================
__pycache__/
*.py[cod]
*$py.class
venv/
.venv/
env/
.env_python/
pip-log.txt

# =========================
# 🐹 GO (O Back-end / API)
# =========================
/backend/bin/
/backend/tmp/
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out

# =========================
# ⚛️ NODE / REACT (O Front-end)
# =========================
node_modules/
/frontend/node_modules/
/frontend/dist/
/frontend/build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache

# =========================
# 🐳 DOCKER & BANCO DE DADOS
